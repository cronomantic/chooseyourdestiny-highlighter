{
  "name": "chooseyourdestiny-highlighter",
  "publisher": "cronomantic",
  "displayName": "ChooseYourDestiny Syntax Highlighter",
  "description": "Syntax Highlighter for ChooseYourDestiny CYOA creation suite.",
  "version": "2.1.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "scripts": {
    "package": "vsce package",
    "package:out": "vsce package --out chooseyourdestiny-highlighter.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/cronomantic/chooseyourdestiny-highlighter"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cyd",
        "aliases": [
          "ChooseYourDestiny",
          "cyd"
        ],
        "extensions": [
          ".cyd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cyd",
        "scopeName": "source.cyd",
        "path": "./syntaxes/cyd.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cyd",
        "path": "./snippets/cyd.code-snippets"
      }
    ],
    "problemMatchers": [
      {
        "name": "cyd",
        "owner": "cyd",
        "source": "cydc",
        "fileLocation": [
          "autoDetect",
          "${workspaceFolder}"
        ],
        "severity": "error",
        "pattern": {
          "regexp": "^ERROR \\[\\w+\\]:\\s*(.*?([A-Za-z0-9_.\\\\/-]+\\.cyd):(\\d+).*)$",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    ]
  }
}
